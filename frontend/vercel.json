{
    "buildCommand": "npm install && npm run build",
    "framework": "nextjs",
    "nodeVersion": "20.x",
    "env": {
        "NEXT_PUBLIC_API_URL": {
            "default": "http://localhost:5000"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "$NEXT_PUBLIC_API_URL/api/:path*"
        }
    ],
    "headers": [
        {
            "source": "/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        }
    ]
}