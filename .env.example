# ============================================================================
# Certificate Practice App - Environment Configuration (TEMPLATE)
# ============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env file with real keys to git repository.
# ============================================================================

# ============== LLM Configuration ==============
# Provider selection: openai | gemini | azure
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o

# OpenAI Configuration (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Google Gemini Configuration (required if LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_MODEL=gemini-1.5-pro

# Azure OpenAI Configuration (required if LLM_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============== Service Ports ==============
FRONTEND_PORT=6005
BACKEND_PORT=5000
AI_CORE_PORT=6100
DATABASE_PORT=5432

# ============== Database Configuration ==============
# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/certidb

# ============== API URLs ==============
# AI Core Service URL (Backend will use this to call AI Core)
AI_CORE_URL=http://localhost:6100

# Frontend API URL (Frontend will use this to call Backend)
NEXT_PUBLIC_API_URL=http://localhost:5000

# ============== Deployment (Vercel/Production) ==============
# These will be set in Vercel environment variables
# NEXT_PUBLIC_API_URL=https://your-backend-url.com
# DATABASE_URL=postgresql://user:password@vercel.postgres.com/dbname
